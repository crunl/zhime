# 知我 — 环境变量配置
# 复制此文件为 .env 并填入实际值（.env 不会被 git 提交）

# 内置模型（默认路由）
# 新用户注册 Makers 后自动注入 AI_GATEWAY_API_KEY，无需手动获取
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1
AI_MODEL=@makers/deepseek-v4-flash

# Coze 扣子（model=coze 时使用，可选）
# ⚠️ 请勿在此填写真实 Token，应通过 `edgeone makers env set` 注入
COZE_TOKEN=
COZE_BOT_ID=7656059514227146792
COZE_API=https://api.coze.cn/v3/chat
